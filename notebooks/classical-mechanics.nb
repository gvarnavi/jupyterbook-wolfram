Cell[CellGroupData[{

Cell["Small-angle Approximation", "Subsection",
 CellChangeTimes->{{3.992674914440688*^9, 
  3.9926749235380163`*^9}},ExpressionUUID->"afd50167-0fd7-48b2-8ae2-\
47c3f581cdf0"],

Cell["\<\
To solve this analytically, you probably made the \
\[OpenCurlyDoubleQuote]small amplitude\[CloseCurlyDoubleQuote] approximation \
in 8.01. For small amplitudes of \[Theta], we may replace sin(\[Theta](t))\
\[Rule]\[Theta](t).\
\>", "Text",
 CellChangeTimes->{{3.9926749290521793`*^9, 
  3.992674942048519*^9}},ExpressionUUID->"3f3c8eff-8815-41f2-a2cb-\
a1c7b9120374"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolveValue", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"\[Theta]", "''"}], "[", "t", "]"}], " ", "+", " ", 
     RowBox[{
      FractionBox["g", "L"], 
      RowBox[{"\[Theta]", "[", "t", "]"}]}]}], "\[Equal]", "0"}], ",", 
   RowBox[{"\[Theta]", "[", "t", "]"}], ",", "t"}], "]"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"4fd81d88-003a-4725-a1e2-fad4a54fa6e3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   TemplateBox[{"1"},
    "C"], " ", 
   RowBox[{"Cos", "[", 
    FractionBox[
     RowBox[{
      SqrtBox["g"], " ", "t"}], 
     SqrtBox["L"]], "]"}]}], "+", 
  RowBox[{
   TemplateBox[{"2"},
    "C"], " ", 
   RowBox[{"Sin", "[", 
    FractionBox[
     RowBox[{
      SqrtBox["g"], " ", "t"}], 
     SqrtBox["L"]], "]"}]}]}]], "Output",
 CellChangeTimes->{3.99267495228974*^9},
 CellLabel->"Out[2]=",ExpressionUUID->"e327ef96-b365-447b-9f0e-5c829d318aec"]
}, Open  ]],

Cell[TextData[{
 "This is a ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "nd"], TraditionalForm]],ExpressionUUID->
  "a7170f89-6fae-4dfa-b8e4-9f8ea3edf165"],
 " order ODE. We therefore need 2 initial conditions to specify the two \
constants above:"
}], "Text",
 CellChangeTimes->{{3.992674963492548*^9, 
  3.992674971285231*^9}},ExpressionUUID->"5784c98b-2fd6-48a5-9dd9-\
1e8e293ddc1b"],

