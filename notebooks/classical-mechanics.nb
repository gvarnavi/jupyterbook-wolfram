Cell["\<\
It is now straight-forward to add multiple pendula with different lengths!\
\>", "Text",
 CellChangeTimes->{{3.992675078021606*^9, 
  3.992675084445628*^9}},ExpressionUUID->"b1f54460-36a5-48f6-b7df-\
792c8eecd8b0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"#", "|", 
    RowBox[{"label", ":", 
     RowBox[{"widget_multiple", "_pendula"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"g", "=", "1"}], ",", 
      RowBox[{"\[Theta]0", "=", 
       RowBox[{"\[Pi]", "/", "12"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Animate", "[", 
     RowBox[{
      RowBox[{"Show", "[", "\[IndentingNewLine]", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"visualizePendulum", "[", "length", "]"}], "[", 
          RowBox[{
           RowBox[{"smallDisplacementSymbolicSolution", "[", 
            RowBox[{"\[Theta]0", ",", "g", ",", "length"}], "]"}], "[", "t", 
           "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"length", ",", 
           RowBox[{"Subdivide", "[", 
            RowBox[{
             RowBox[{"1", "/", "2"}], ",", "1", ",", "10"}], "]"}]}], "}"}]}],
         "]"}], "\[IndentingNewLine]", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "60"}], "}"}], ",", 
      RowBox[{"AnimationRate", "\[Rule]", "5"}], ",", 
      RowBox[{"AnimationRunning", "\[Rule]", "False"}], ",", 
      RowBox[{"Paneled", "\[Rule]", "False"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.9926750969298897`*^9, 
  3.992675172269792*^9}},ExpressionUUID->"8997118b-aa0c-4551-8b50-\
