Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"smallDisplacementSymbolicSolution", "[", 
    RowBox[{"\[Theta]0_", ",", "g_", ",", "L_"}], "]"}], "[", "t_", "]"}], "=", 
  RowBox[{"DSolveValue", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"\[Theta]", "''"}], "[", "t", "]"}], " ", "+", " ", 
        RowBox[{
         FractionBox["g", "L"], 
         RowBox[{"\[Theta]", "[", "t", "]"}]}]}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{"\[Theta]", "[", "0", "]"}], "==", "\[Theta]0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Theta]", "'"}], "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
    RowBox[{"\[Theta]", "[", "t", "]"}], ",", "t"}], "]"}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"31433d92-dd92-4b52-a80c-e416d7f25913"],

Cell[BoxData[
 RowBox[{"\[Theta]0", " ", 
  RowBox[{"Cos", "[", 
   FractionBox[
    RowBox[{
     SqrtBox["g"], " ", "t"}], 
    SqrtBox["L"]], "]"}]}]], "Output",
 CellChangeTimes->{3.992674987126875*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"6ab3b061-d832-4d74-b0db-02ab97ea5f16"]
}, Open  ]]
}, Open  ]],

Cell[TextData[{
 StyleBox["Coding comment: ",
  FontWeight->"Bold"],
 "We used the pattern ",
 StyleBox["function[paramA_,paramB_][argument_] = ...",
  FontSlant->"Italic"],
 "\n\nWill use this pattern frequently, as it achieves two convenient tasks:\n\
\t1.  \tSeparates arguments and parameters, so we can use forms like: \
\[LineSeparator]\t\t\t",
 StyleBox["function[paramA,paramB]/@listOfArguments",
  FontSlant->"Italic"],
 "\n\t2.\tProvides a convenient way of assigning symbols to expressions, as \
opposed to something like:\n\t\t\t",
 StyleBox["expressionRHS /.{paramA->.., paramB->..}",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{
  3.992674997205861*^9},ExpressionUUID->"e13d7439-e70e-4a7d-94a0-\
c953ee0d6132"],

Cell[TextData[{
 "The solution is a simple sinusoidal term with a natural frequency ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Omega]", "=", 
    SqrtBox[
     RowBox[{"g", "/", "L"}]]}], TraditionalForm]],ExpressionUUID->
  "298a9628-adf9-445b-95dd-1eb9a228897d"],
 ". \nLet\[CloseCurlyQuote]s animate one such pendulum, for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"g", "=", "1"}], ",", 
    RowBox[{"L", "=", "1"}], ",", 
    RowBox[{
     SubscriptBox["\[Theta]", "0"], "=", 
     RowBox[{"\[Pi]", "/", "12"}]}]}], TraditionalForm]],ExpressionUUID->
  "5b876cdb-da50-4745-98f7-f8f8592b7602"]
}], "Text",
 CellChangeTimes->{{3.992675010400385*^9, 
  3.992675028245468*^9}},ExpressionUUID->"bd1a405c-1754-49a9-9928-\
4a7713d27818"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"visualizePendulum", "[", 
    RowBox[{"length_", ",", 
     RowBox[{"color_", ":", "White"}]}], "]"}], "[", "angle_", "]"}], ":=", 
  RowBox[{"Graphics", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"color", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0"}], "}"}], ",", 
           RowBox[{"length", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Sin", "[", "angle", "]"}], ",", 
              RowBox[{"-", 
               RowBox[{"Cos", "[", "angle", "]"}]}]}], "}"}]}]}], "}"}], 
         "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"color", ",", 
        RowBox[{"PointSize", "[", "Large", "]"}], ",", 
        RowBox[{"Point", "[", 
         RowBox[{"length", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Sin", "[", "angle", "]"}], ",", 
            RowBox[{"-", 
             RowBox[{"Cos", "[", "angle", "]"}]}]}], "}"}]}], "]"}]}], 
       "}"}]}], "\[IndentingNewLine]", "}"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"1.025", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "0"}], "}"}]}], "}"}]}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9926750649822474`*^9, 3.9926750659734383`*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"5851363e-8cf2-4bfe-905a-2f93c1809cf5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"#", "|", 
    RowBox[{"label", ":", 
     RowBox[{"widget_single", "_pendulum"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"g", "=", "1"}], ",", 
      RowBox[{"\[Theta]0", "=", 
       RowBox[{"\[Pi]", "/", "12"}]}], ",", 
      RowBox[{"L", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Animate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"visualizePendulum", "[", "L", "]"}], "[", 
       RowBox[{
        RowBox[{"smallDisplacementSymbolicSolution", "[", 
         RowBox[{"\[Theta]0", ",", "g", ",", "L"}], "]"}], "[", "t", "]"}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "60"}], "}"}], ",", 
      RowBox[{"AnimationRate", "\[Rule]", "5"}], ",", 
      RowBox[{"AnimationRunning", "\[Rule]", "False"}], ",", 
      RowBox[{"Paneled", "\[Rule]", "False"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{
  3.992675049506262*^9, {3.9926751429435368`*^9, 
   3.992675162935566*^9}},ExpressionUUID->"fe6fba92-06e5-423f-894a-\
8101c525a5fe"],

